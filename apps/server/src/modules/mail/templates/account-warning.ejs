<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Account Warning - Vibe-message</title>
</head>
<body style="margin:0; padding:0; background:#F8F7FC; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif; color:#1F2937;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#F8F7FC; padding:32px 12px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:640px;">
          <tr>
            <td style="padding:0 0 18px;">
              <table role="presentation" cellspacing="0" cellpadding="0">
                <tr>
                  <td style="vertical-align:middle; padding-right:10px;">
                    <img src="https://vibemessage.sailorlabs.in/favicon.png" width="36" height="36" alt="Vibe-message" style="display:block; border-radius:10px;" />
                  </td>
                  <td style="vertical-align:middle;">
                    <div style="font-size:18px; line-height:22px; font-weight:800; color:#1F2937;">Vibe-message</div>
                    <div style="font-size:12px; line-height:16px; color:#6B7280;">Account notice</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="background:#FFFFFF; border:1px solid #E5E7EB; border-radius:18px; overflow:hidden; box-shadow:0 18px 50px rgba(15,23,42,0.08);">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                <tr>
                  <td style="background:#8B5CF6; padding:34px 36px 32px;">
                    <div style="display:inline-block; background:#FDE68A; color:#1F2937; border-radius:999px; padding:7px 12px; font-size:12px; font-weight:800; letter-spacing:.4px; text-transform:uppercase;">Warning</div>
                    <h1 style="margin:18px 0 8px; color:#FFFFFF; font-size:30px; line-height:38px; font-weight:800;">Please review your account activity.</h1>
                    <p style="margin:0; color:#F9FAFB; font-size:16px; line-height:25px;">An administrator issued a warning on your Vibe-message account.</p>
                  </td>
                </tr>

                <tr>
                  <td style="padding:34px 36px 12px;">
                    <p style="margin:0 0 20px; color:#1F2937; font-size:15px; line-height:25px;">
                      Hi <strong><%= name %></strong>, please read the administrator message below and make any required changes to your usage.
                    </p>

                    <div style="background:#F1F0FA; border:1px solid #FDE68A; border-left:4px solid #FDE68A; border-radius:14px; padding:18px 20px; margin:0 0 24px;">
                      <div style="font-size:12px; color:#1F2937; font-weight:900; text-transform:uppercase; letter-spacing:.6px; margin-bottom:8px;">Administrator Message</div>
                      <div style="font-size:16px; line-height:26px; color:#1F2937; font-weight:600;">"<%= warningMessage %>"</div>
                    </div>

                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin:0 0 24px;">
                      <tr>
                        <td style="padding:16px; background:#F1F0FA; border:1px solid #E5E7EB; border-radius:14px;">
                          <div style="font-size:13px; color:#6B7280; font-weight:800; text-transform:uppercase; letter-spacing:.4px; margin-bottom:10px;">Recommended next step</div>
                          <div style="font-size:15px; line-height:25px; color:#1F2937;">
                            Review your recent activity, stop any behavior mentioned above, and contact support if you believe this warning was sent by mistake.
                          </div>
                        </td>
                      </tr>
                    </table>

                    <table role="presentation" cellspacing="0" cellpadding="0" style="margin:10px 0 24px;">
                      <tr>
                        <td bgcolor="#A78BFA" style="border-radius:10px;">
                          <a href="https://vibemessage.sailorlabs.in" style="display:inline-block; padding:13px 22px; color:#FFFFFF; text-decoration:none; font-size:14px; font-weight:800;">Open Dashboard</a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <tr>
                  <td style="padding:22px 36px 30px; border-top:1px solid #E5E7EB;">
                    <p style="margin:0; color:#6B7280; font-size:12px; line-height:20px;">This warning was issued by a Vibe-message administrator. Repeated violations may lead to restrictions.</p>
                    <p style="margin:10px 0 0; color:#9CA3AF; font-size:12px;">Copyright <%= new Date().getFullYear() %> Vibe-message. All rights reserved.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
