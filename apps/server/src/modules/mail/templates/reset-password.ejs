<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reset Your Password - Vibe-message</title>
</head>
<body style="margin:0; padding:0; background:#F8F7FC; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif; color:#1F2937;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#F8F7FC; padding:32px 12px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:640px;">
          <tr>
            <td style="padding:0 0 18px;">
              <table role="presentation" cellspacing="0" cellpadding="0">
                <tr>
                  <td style="vertical-align:middle; padding-right:10px;">
                    <img src="https://vibemessage.sailorlabs.in/favicon.png" width="36" height="36" alt="Vibe-message" style="display:block; border-radius:10px;" />
                  </td>
                  <td style="vertical-align:middle;">
                    <div style="font-size:18px; line-height:22px; font-weight:800; color:#1F2937;">Vibe-message</div>
                    <div style="font-size:12px; line-height:16px; color:#6B7280;">Notification infrastructure for modern teams</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="background:#FFFFFF; border:1px solid #E5E7EB; border-radius:18px; overflow:hidden; box-shadow:0 18px 50px rgba(15,23,42,0.08);">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                <tr>
                  <td style="background:#8B5CF6; padding:34px 36px 32px;">
                    <div style="display:inline-block; background:#FDE68A; color:#1F2937; border-radius:999px; padding:7px 12px; font-size:12px; font-weight:800; letter-spacing:.4px; text-transform:uppercase;">Password Reset</div>
                    <h1 style="margin:18px 0 8px; color:#FFFFFF; font-size:30px; line-height:38px; font-weight:800;">Reset your password.</h1>
                    <p style="margin:0; color:#F9FAFB; font-size:16px; line-height:25px;">Hi <%= name %>, we received a request to reset your Vibe-message account password.</p>
                  </td>
                </tr>

                <tr>
                  <td style="padding:34px 36px 12px;">
                    <p style="margin:0 0 20px; color:#1F2937; font-size:15px; line-height:25px;">
                      Click the button below to choose a new password. This link is valid for <strong>15 minutes</strong> and can only be used once.
                    </p>

                    <table role="presentation" cellspacing="0" cellpadding="0" style="margin:10px 0 28px;">
                      <tr>
                        <td bgcolor="#8B5CF6" style="border-radius:10px;">
                          <a href="<%= resetUrl %>" style="display:inline-block; padding:14px 28px; color:#FFFFFF; text-decoration:none; font-size:15px; font-weight:800;">Reset My Password</a>
                        </td>
                      </tr>
                    </table>

                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin:0 0 24px;">
                      <tr>
                        <td style="padding:16px; background:#F1F0FA; border:1px solid #E5E7EB; border-radius:14px;">
                          <div style="font-size:12px; color:#6B7280; font-weight:700; text-transform:uppercase; letter-spacing:.4px; margin-bottom:8px;">Or copy this link</div>
                          <div style="font-size:13px; line-height:20px; color:#8B5CF6; word-break:break-all;"><%= resetUrl %></div>
                        </td>
                      </tr>
                    </table>

                    <div style="background:#FEF3C7; border-left:4px solid #F59E0B; border-radius:12px; padding:14px 16px; color:#92400E; font-size:13px; line-height:22px;">
                      If you did not request a password reset, you can safely ignore this email. Your account remains secure.
                    </div>
                  </td>
                </tr>

                <tr>
                  <td style="padding:22px 36px 30px; border-top:1px solid #E5E7EB;">
                    <p style="margin:0; color:#6B7280; font-size:12px; line-height:20px;">
                      This link will expire in 15 minutes. If you need a new link, visit the login page and click "Forgot password?" again.
                    </p>
                    <p style="margin:10px 0 0; color:#9CA3AF; font-size:12px;">Copyright <%= new Date().getFullYear() %> Vibe-message. All rights reserved.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
