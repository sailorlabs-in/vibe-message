<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= isUpdate ? 'App Access Updated' : 'App Access Granted' %> - Vibe-message</title>
</head>
<body style="margin:0; padding:0; background:#F8F7FC; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif; color:#1F2937;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#F8F7FC; padding:32px 12px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:640px;">
          <tr>
            <td style="padding:0 0 18px;">
              <table role="presentation" cellspacing="0" cellpadding="0">
                <tr>
                  <td style="vertical-align:middle; padding-right:10px;">
                    <img src="https://vibemessage.sailorlabs.in/favicon.png" width="36" height="36" alt="Vibe-message" style="display:block; border-radius:10px;" />
                  </td>
                  <td style="vertical-align:middle;">
                    <div style="font-size:18px; line-height:22px; font-weight:800; color:#1F2937;">Vibe-message</div>
                    <div style="font-size:12px; line-height:16px; color:#6B7280;">Team access notification</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="background:#FFFFFF; border:1px solid #E5E7EB; border-radius:18px; overflow:hidden; box-shadow:0 18px 50px rgba(15,23,42,0.08);">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                <tr>
                  <td style="background:#8B5CF6; padding:34px 36px 32px;">
                    <div style="display:inline-block; background:#D1FAE5; color:#1F2937; border-radius:999px; padding:7px 12px; font-size:12px; font-weight:800; letter-spacing:.4px; text-transform:uppercase;"><%= isUpdate ? 'Access Updated' : 'Access Granted' %></div>
                    <h1 style="margin:18px 0 8px; color:#FFFFFF; font-size:30px; line-height:38px; font-weight:800;"><%= isUpdate ? 'Your app role changed.' : 'You have access to an app.' %></h1>
                    <p style="margin:0; color:#F9FAFB; font-size:16px; line-height:25px;">
                      <% if (isUpdate) { %>
                        Your role on <%= appName %> has been updated.
                      <% } else { %>
                        <%= ownerName %> added you as a collaborator.
                      <% } %>
                    </p>
                  </td>
                </tr>

                <tr>
                  <td style="padding:34px 36px 12px;">
                    <p style="margin:0 0 20px; color:#1F2937; font-size:15px; line-height:25px;">
                      Hi <strong><%= name %></strong>,
                      <% if (isUpdate) { %>
                        <strong><%= ownerName %></strong> updated your access role for the app below.
                      <% } else { %>
                        <strong><%= ownerName %></strong> granted you access to collaborate on the app below.
                      <% } %>
                    </p>

                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin:0 0 24px;">
                      <tr>
                        <td style="padding:20px; background:#F1F0FA; border:1px solid #E5E7EB; border-radius:14px;">
                          <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                            <tr>
                              <td style="vertical-align:top; width:54px;">
                                <div style="width:42px; height:42px; background:#D1FAE5; border-radius:12px; color:#1F2937; font-size:22px; line-height:42px; text-align:center; font-weight:900;"><%= appName.substring(0,1) %></div>
                              </td>
                              <td style="vertical-align:top;">
                                <div style="font-size:18px; line-height:24px; color:#1F2937; font-weight:900;"><%= appName %></div>
                                <div style="font-size:13px; line-height:20px; color:#6B7280;">Shared by <%= ownerName %></div>
                                <div style="margin-top:12px;">
                                  <% if (role === 'moderator') { %>
                                    <span style="display:inline-block; background:#EDE9FE; color:#1F2937; border-radius:999px; padding:7px 12px; font-size:12px; font-weight:900; text-transform:uppercase; letter-spacing:.4px;">Moderator</span>
                                  <% } else { %>
                                    <span style="display:inline-block; background:#93C5FD; color:#1F2937; border-radius:999px; padding:7px 12px; font-size:12px; font-weight:900; text-transform:uppercase; letter-spacing:.4px;">Viewer</span>
                                  <% } %>
                                </div>
                              </td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>

                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin:0 0 24px;">
                      <tr>
                        <td style="padding:16px; background:#FFFFFF; border:1px solid #E5E7EB; border-radius:14px;">
                          <div style="font-size:13px; color:#6B7280; font-weight:800; text-transform:uppercase; letter-spacing:.4px; margin-bottom:12px;">Your permissions</div>
                          <% if (role === 'moderator') { %>
                            <div style="font-size:15px; line-height:27px; color:#1F2937;">Allowed: view analytics, send notifications, manage subscribers, and work with drip campaigns.</div>
                            <div style="font-size:15px; line-height:27px; color:#6B7280;">Restricted: sharing/removing members, deleting apps, and rotating keys.</div>
                          <% } else { %>
                            <div style="font-size:15px; line-height:27px; color:#1F2937;">Allowed: view app details, analytics, and notification history.</div>
                            <div style="font-size:15px; line-height:27px; color:#6B7280;">Restricted: sending notifications, managing subscribers, editing campaigns, and member actions.</div>
                          <% } %>
                        </td>
                      </tr>
                    </table>

                    <table role="presentation" cellspacing="0" cellpadding="0" style="margin:10px 0 24px;">
                      <tr>
                        <td bgcolor="#6EE7B7" style="border-radius:10px;">
                          <a href="https://vibemessage.sailorlabs.in" style="display:inline-block; padding:13px 22px; color:#1F2937; text-decoration:none; font-size:14px; font-weight:800;">Open App</a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <tr>
                  <td style="padding:22px 36px 30px; border-top:1px solid #E5E7EB;">
                    <p style="margin:0; color:#6B7280; font-size:12px; line-height:20px;">This <%= isUpdate ? 'access update' : 'invitation' %> was initiated by <%= ownerName %> on Vibe-message. Contact support if you did not expect this.</p>
                    <p style="margin:10px 0 0; color:#9CA3AF; font-size:12px;">Copyright <%= new Date().getFullYear() %> Vibe-message. All rights reserved.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
