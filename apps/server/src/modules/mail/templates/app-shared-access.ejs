<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= isUpdate ? 'App Access Updated' : 'App Access Granted' %> — <%= appName %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: #0f0f13;
      color: #e2e8f0;
      min-height: 100vh;
      padding: 40px 16px;
    }
    .wrapper { max-width: 580px; margin: 0 auto; }
    .header { text-align: center; padding: 0 0 32px; }
    .logo-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      border: 1px solid rgba(16,185,129,0.25);
      border-radius: 12px;
      padding: 10px 20px;
      margin-bottom: 28px;
    }
    .logo-icon {
      width: 32px; height: 32px;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      border-radius: 8px; font-size: 18px;
      display: flex; align-items: center; justify-content: center;
    }
    .logo-text { font-size: 15px; font-weight: 600; color: #6ee7b7; letter-spacing: 0.5px; }
    .card {
      background: linear-gradient(145deg, #141420 0%, #0d1a14 100%);
      border: 1px solid rgba(16,185,129,0.2);
      border-radius: 20px;
      overflow: hidden;
    }
    .hero {
      background: linear-gradient(135deg, #052014 0%, #073d21 50%, #052014 100%);
      padding: 48px 40px 40px;
      text-align: center;
      position: relative;
      border-bottom: 1px solid rgba(16,185,129,0.25);
    }
    .hero-glow {
      position: absolute; top: -40px; left: 50%;
      transform: translateX(-50%);
      width: 200px; height: 200px;
      background: radial-gradient(circle, rgba(16,185,129,0.3) 0%, transparent 70%);
      pointer-events: none;
    }
    .share-icon {
      width: 80px; height: 80px;
      background: linear-gradient(135deg, #059669, #065f46);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 20px;
      font-size: 38px;
      box-shadow: 0 0 40px rgba(16,185,129,0.5), 0 0 80px rgba(16,185,129,0.2);
    }
    .hero h1 { font-size: 28px; font-weight: 700; color: #fff; letter-spacing: -0.5px; line-height: 1.3; margin-bottom: 10px; }
    .hero p { font-size: 15px; color: #6ee7b7; line-height: 1.6; }
    .content { padding: 36px 40px; }
    .greeting { font-size: 16px; color: #cbd5e1; margin-bottom: 28px; line-height: 1.7; }
    .greeting strong { color: #e2e8f0; }
    /* App card */
    .app-card {
      background: rgba(16,185,129,0.06);
      border: 1px solid rgba(16,185,129,0.2);
      border-radius: 16px;
      padding: 24px;
      margin: 8px 0 28px;
      display: flex;
      gap: 18px;
      align-items: flex-start;
    }
    .app-avatar {
      width: 56px; height: 56px;
      background: linear-gradient(135deg, #059669, #10b981);
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 26px;
      flex-shrink: 0;
    }
    .app-info { flex: 1; }
    .app-name { font-size: 18px; font-weight: 700; color: #fff; margin-bottom: 4px; }
    .app-meta { font-size: 13px; color: #64748b; margin-bottom: 12px; }
    /* Role badge */
    .role-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border-radius: 20px;
      padding: 5px 14px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.3px;
    }
    .role-moderator {
      background: rgba(139,92,246,0.15);
      border: 1px solid rgba(139,92,246,0.4);
      color: #c4b5fd;
    }
    .role-viewer {
      background: rgba(14,165,233,0.12);
      border: 1px solid rgba(14,165,233,0.35);
      color: #7dd3fc;
    }
    /* Permissions */
    .permissions { margin: 0 0 28px; }
    .perm-title { font-size: 13px; font-weight: 600; color: #64748b; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 12px; }
    .perm-list { display: flex; flex-direction: column; gap: 8px; }
    .perm-item {
      display: flex; align-items: center; gap: 10px;
      font-size: 14px; color: #94a3b8; line-height: 1.5;
    }
    .perm-check { font-size: 15px; }
    .perm-no { font-size: 15px; opacity: 0.4; }
    .cta-wrap { text-align: center; margin: 28px 0 8px; }
    .cta-btn {
      display: inline-block;
      background: linear-gradient(135deg, #059669, #10b981);
      color: #fff !important;
      text-decoration: none;
      padding: 14px 40px;
      border-radius: 12px;
      font-size: 15px;
      font-weight: 600;
      letter-spacing: 0.3px;
      box-shadow: 0 4px 24px rgba(16,185,129,0.4);
    }
    .divider { height: 1px; background: linear-gradient(90deg, transparent, rgba(16,185,129,0.15), transparent); margin: 32px 0; }
    .footer { text-align: center; padding: 0 40px 32px; }
    .footer p { font-size: 12px; color: #475569; line-height: 1.8; }
    .footer a { color: #10b981; text-decoration: none; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <div class="logo-badge">
        <div class="logo-icon">💬</div>
        <span class="logo-text"><%= appName %></span>
      </div>
    </div>

    <div class="card">
      <div class="hero">
        <div class="hero-glow"></div>
        <div class="share-icon"><%= isUpdate ? '🔄' : '🔗' %></div>
        <h1><%= isUpdate ? 'App Access Updated' : 'App Access Granted' %></h1>
        <p>
          <% if (isUpdate) { %>
            Your role in <strong><%= appName2 || appName %></strong> has been updated, <%= name %>.
          <% } else { %>
            You've been invited to collaborate on an app, <%= name %>.
          <% } %>
        </p>
      </div>

      <div class="content">
        <p class="greeting">
          Hi <strong><%= name %></strong>,<br /><br />
          <% if (isUpdate) { %>
            <strong><%= ownerName %></strong> has <strong style="color:#6ee7b7;">updated your role</strong> 
            in the following app on <strong><%= appName %></strong>:
          <% } else { %>
            <strong><%= ownerName %></strong> has <strong style="color:#6ee7b7;">granted you access</strong> 
            as a collaborator on the following app in <strong><%= appName %></strong>:
          <% } %>
        </p>

        <!-- App card -->
        <div class="app-card">
          <div class="app-avatar">📱</div>
          <div class="app-info">
            <div class="app-name"><%= appName2 || appName %></div>
            <div class="app-meta">Shared by <%= ownerName %></div>
            <% if (role === 'moderator') { %>
              <span class="role-badge role-moderator">🛡️ Moderator</span>
            <% } else { %>
              <span class="role-badge role-viewer">👁️ Viewer</span>
            <% } %>
          </div>
        </div>

        <!-- Permissions based on role -->
        <div class="permissions">
          <div class="perm-title">Your Permissions</div>
          <div class="perm-list">
            <% if (role === 'moderator') { %>
              <div class="perm-item"><span class="perm-check">✅</span> View app details & analytics</div>
              <div class="perm-item"><span class="perm-check">✅</span> Send push notifications</div>
              <div class="perm-item"><span class="perm-check">✅</span> Manage subscribers</div>
              <div class="perm-item"><span class="perm-check">✅</span> View & edit drip campaigns</div>
              <div class="perm-item"><span class="perm-no">🚫</span> <span style="opacity:0.5">Share or remove app members</span></div>
              <div class="perm-item"><span class="perm-no">🚫</span> <span style="opacity:0.5">Delete the app or rotate keys</span></div>
            <% } else { %>
              <div class="perm-item"><span class="perm-check">✅</span> View app details & analytics</div>
              <div class="perm-item"><span class="perm-check">✅</span> View notification history</div>
              <div class="perm-item"><span class="perm-no">🚫</span> <span style="opacity:0.5">Send push notifications</span></div>
              <div class="perm-item"><span class="perm-no">🚫</span> <span style="opacity:0.5">Manage subscribers or drip campaigns</span></div>
              <div class="perm-item"><span class="perm-no">🚫</span> <span style="opacity:0.5">Share or remove app members</span></div>
            <% } %>
          </div>
        </div>

        <div class="cta-wrap">
          <a class="cta-btn" href="#">Open App →</a>
        </div>
      </div>

      <div class="divider"></div>

      <div class="footer">
        <p>
          This <%= isUpdate ? 'update' : 'invitation' %> was initiated by <strong><%= ownerName %></strong> on <%= appName %>.<br />
          If you didn't expect this, please <a href="#">contact support</a>.
        </p>
        <p style="margin-top: 8px;">© <%= new Date().getFullYear() %> <%= appName %>. All rights reserved.</p>
      </div>
    </div>
  </div>
</body>
</html>
